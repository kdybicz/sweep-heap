{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.3-codex",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    }
  },
  "default_agent": "plan",
  "share": "disabled",
  "watcher": {
    "ignore": ["node_modules/**", ".next/**", "coverage/**", ".serverless/**", ".git/**"]
  }
}
