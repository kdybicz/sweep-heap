{
  "name": "chores",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "next dev",
    "email:dev": "XDG_CONFIG_HOME=.react-email/config email dev --dir src/lib/email/templates --port 3001",
    "seed:chores": "node scripts/seed-chores.mjs",
    "db:reset": "node scripts/reset-db.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit && echo \"Type check passed!\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format .",
    "format:write": "biome format . --write",
    "dev:check": "yarn format && yarn lint && yarn test && yarn typecheck",
    "dev:fix": "yarn format:write && yarn lint:fix && yarn test && yarn typecheck"
  },
  "dependencies": {
    "@react-email/components": "1.0.10",
    "@react-email/render": "2.0.4",
    "@tanstack/react-query": "5.95.2",
    "better-auth": "1.5.6",
    "drizzle-orm": "0.45.1",
    "luxon": "3.7.2",
    "next": "16.2.1",
    "nodemailer": "8.0.3",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "4.2.2",
    "@types/luxon": "3.7.1",
    "@types/node": "24.12.0",
    "@types/nodemailer": "7.0.11",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.0.1",
    "react-email": "5.2.10",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.1"
  },
  "resolutions": {
    "minimatch": "10.2.4",
    "picomatch": "4.0.4",
    "tar": "7.5.13"
  }
}
