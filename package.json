{
  "name": "chores",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "next dev",
    "seed:chores": "node scripts/seed-chores.mjs",
    "db:reset": "node scripts/reset-db.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format .",
    "format:write": "biome format . --write",
    "dev:check": "yarn format && yarn lint && yarn test && yarn typecheck",
    "dev:fix": "yarn format:write && yarn lint:fix && yarn test && yarn typecheck"
  },
  "dependencies": {
    "luxon": "^3.5.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tailwindcss/postcss": "^4",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
